# Discord
DISCORD_TOKEN=replace_me
DISCORD_GUILD_ID=682111264599965736
DISCORD_GM_ROLE_IDS=
DISCORD_ADMIN_CHANNEL_ID=
DISCORD_GM_REVIEW_CHANNEL_ID=
DISCORD_CHARACTER_REGISTRY_CHANNEL_ID=707461395209256982
DISCORD_COMMAND_PREFIX=!

# Database and cache
POSTGRES_DB=faervell
POSTGRES_USER=faervell
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://faervell:change_me@postgres:5432/faervell
REDIS_URL=redis://redis:6379/0
AUTO_CREATE_SCHEMA=true

# OpenRouter. ACTOR_MODELS / PLANNER_MODELS are preferred orders, not allowlists.
# All live free text models from /models are eligible except MODEL_BLOCKLIST.
# Paid models are eligible only when both token prices fit the limits below.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/LuwnFM/faervell-ai-npc
OPENROUTER_APP_NAME=Faervell Stranger NPC
ACTOR_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,deepseek/deepseek-v4-flash
PLANNER_MODELS=deepseek/deepseek-v4-flash,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free
MODEL_BLOCKLIST=openrouter/free,openrouter/auto,openai/gpt-oss-20b,nvidia/nemotron-nano-9b-v2,laguna-2.1-xs,laguna-2-1-xs
OPENROUTER_ALLOW_PAID_FALLBACK=true
OPENROUTER_DYNAMIC_CATALOG=true
OPENROUTER_CATALOG_TTL_SECONDS=1800
OPENROUTER_MAX_CATALOG_CANDIDATES=24
OPENROUTER_MAX_PROMPT_PRICE_PER_MILLION=0.20
OPENROUTER_MAX_COMPLETION_PRICE_PER_MILLION=0.20
# 0 means: models with a non-zero fixed per-request fee are rejected; the field is not sent.
OPENROUTER_MAX_REQUEST_PRICE_USD=0.0
OPENROUTER_PLANNER_REASONING_EFFORT=high
ACTOR_MAX_TOKENS=1000
PLANNER_MAX_TOKENS=1600
PLANNER_DAILY_BUDGET_USD=2.00
PLANNER_ESCALATION_ENABLED=true

# Runtime
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=ru
PSEUDONYM_SECRET=replace_with_long_random_secret
EMBEDDING_PROVIDER=hashing
EMBEDDING_DIMENSIONS=384
SEMANTIC_MODEL=intfloat/multilingual-e5-small
MAX_RECENT_MESSAGES=24
MAX_RETRIEVED_MEMORIES=5
MAX_RETRIEVED_KNOWLEDGE=6
BOT_REPLY_COOLDOWN_SECONDS=2
DISCORD_REPLY_HINT_TEXT=Чтобы продолжить разговор со Странником, упомяните его в своём сообщении или ответьте на один из его постов.
DISCORD_MODEL_FOOTER_ENABLED=true
DISCORD_REGENERATION_LIMIT=1

# Presence and RP geography
TRAVELER_PRESENCE_ENABLED=true
TRAVELER_MOVEMENT_INTERVAL_SECONDS=600
TRAVELER_DEFAULT_APPEARANCE_PROBABILITY=0.20
TRAVELER_SUMMON_MOVE_CHANCE=0.75
TRAVELER_CROSS_LOCATION_MIN_SCORE=0.58
TRAVELER_AUTO_REGISTER_LOCATIONS=true
# 1.0 safety: hard-lock every process start to this channel. GM's
# /stranger movement_lock enabled:false releases it for the weighted location roll.
TRAVELER_ENFORCE_STARTUP_LOCK=true
TRAVELER_STARTUP_LOCK_CHANNEL_ID=1488544832950374481
TRAVELER_RP_CATEGORY_IDS=682909341300293662,1057679719597879437,1133768572510941276,1255157727278403614,1426883198327193640,1057717821552984194,1459852302071631988
TRAVELER_EVENTS_CATEGORY_ID=1058403455934398495
TRAVELER_MANUAL_ONLY_CATEGORY_IDS=730030732185043004,1490668605594013776

# Knowledge and character registry
KNOWLEDGE_AUTO_INGEST=true
KNOWLEDGE_MIN_WIKI_DOCUMENTS=689
KNOWLEDGE_STALE_HOURS=24
FANDOM_API_CONCURRENCY=4
CHARACTER_MATCH_THRESHOLD=0.22
CHARACTER_MATCH_MARGIN=0.04

OPENROUTER_RESPONSE_TIMEOUT_SECONDS=180
ACTOR_QUALITY_ATTEMPTS=3
FANDOM_BATCH_SIZE=40
QUEST_DEFAULT_REWARD_AMOUNT=5
QUEST_DEFAULT_REWARD_CURRENCY=местных монет

# v0.8 Discord knowledge sources
DISCORD_WORLD_NEWS_FORUM_ID=1320514974396973186
DISCORD_WORLD_NEWS_AUTHOR_IDS=855605848105287711,331217779019481089
DISCORD_LOCATION_SYNC_TIMEOUT_SECONDS=480
DISCORD_LOCATION_CHANNEL_TIMEOUT_SECONDS=90
DISCORD_LOCATION_MAX_THREADS=500
DISCORD_LOCATION_MAX_MESSAGES=2000
DISCORD_LOCATION_SYNC_CONCURRENCY=3
DISCORD_LOCATION_LONG_MESSAGE_MIN_CHARS=220
CHARACTER_REGISTRY_AUTO_SYNC_ENABLED=true
CHARACTER_REGISTRY_SYNC_INTERVAL_HOURS=48

# Traveler Memory v2 / 1.0.0 (adaptive PostgreSQL Cortex)
TRAVELER_MEMORY_V2_ENABLED=true
TRAVELER_MEMORY_V2_WRITE_ENABLED=true
TRAVELER_MEMORY_V2_READ_ENABLED=true
MEMORY_PERSONAL_ENABLED=true
MEMORY_TESTIMONY_ENABLED=true
MEMORY_WORLD_TESTIMONY_ENABLED=true
MEMORY_CLAIMS_ENABLED=true
MEMORY_EVIDENCE_ENABLED=true
MEMORY_ADAPTIVE_CONTEXT_ENABLED=true
MEMORY_CONTEXT_RESERVE_MODE=adaptive
MEMORY_INCLUDE_LOW_SCORE_WHEN_SPACE=true
MEMORY_DEDUP_VECTOR_THRESHOLD=0.92
MEMORY_DEDUP_LEXICAL_THRESHOLD=0.72
MEMORY_CANDIDATE_POOL=64
MEMORY_GRAPH_ENABLED=false
MEMORY_LLM_UPDATE_ENABLED=false
MEMORY_BACKGROUND_LIFE_ENABLED=false
MEMORY_ALLOW_CROSS_CHARACTER_TESTIMONY=true
MEMORY_REQUIRE_ATTRIBUTION=true
MEMORY_MULTIPLE_SOURCES_CONFIRM=false
MEMORY_CANON_OVERRIDES_TESTIMONY=true
MODEL_CONTEXT_LENGTH=8192
# Global actor invariant: queued travel never interrupts an active RP scene.
TRAVELER_SCENE_SETTLE_SECONDS=900
